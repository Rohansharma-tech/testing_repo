# =============================================
# Environment Variables - Copy this to .env
# and fill in your values
# =============================================

# Server Port
PORT=5000

# MongoDB Connection String
# Use MongoDB Atlas
MONGO_URI=mongodb+srv://rohan:rohan%402005@cluster0.kmbciyi.mongodb.net/attendance_db?retryWrites=true&w=majority

# JWT Secret Key (change this to a random long string)
JWT_SECRET=myAttendanceSystemSecretKey2024

# ---- GEOFENCE SETTINGS ----
# Set the latitude & longitude of your allowed attendance location
# Example below is Chennai, Tamil Nadu
GEOFENCE_LAT=10.786760
GEOFENCE_LNG=78.689341

# Allowed radius in meters (100 = 100 meters from the point above)
GEOFENCE_RADIUS=100

# Maximum acceptable GPS accuracy in meters
MAX_LOCATION_ACCURACY_METERS=200

# Maximum age of the accepted GPS fix in milliseconds
MAX_LOCATION_AGE_MS=120000
